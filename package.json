{
  "name": "asiri",
  "version": "0.1.12",
  "private": true,
  "description": "Asiri website, Cloudflare-style control plane, and local runtime CLI for agent-first secrets access.",
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:ts && node scripts/build-site.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:ts && node --experimental-sqlite --test build/tests/*.test.js",
    "qa": "npm run lint && npm run test && npm run build",
    "smoke:full": "npm run build && ASIRI_ALLOW_UNTRUSTED_RELEASE_KEY=1 ASIRI_CLI_TARGETS='linux/amd64 linux/arm64' npm run package:cli && node scripts/full-smoke.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:local": "node --experimental-sqlite scripts/dev-site.mjs",
    "serve": "npm run build && node --experimental-sqlite scripts/serve-local.mjs",
    "cloudflare:dev": "npm run build && wrangler dev --local --ip 127.0.0.1 --port 8787 --persist-to .wrangler/state",
    "cloudflare:smoke": "npm run build && node scripts/cloudflare-smoke.mjs",
    "cloudflare:deploy": "npm run prod:check && npm run build && wrangler d1 migrations apply asiri-prod --env production --remote && wrangler deploy --env production",
    "prod:check": "node scripts/production-check.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:guard": "node scripts/check-cli-release-version.mjs",
    "release:cli": "npm run release:check && npm run package:cli:smoke",
    "release:publish-r2": "./scripts/publish-cli-r2.sh",
    "package:cli": "./scripts/package-cli.sh",
    "package:cli:smoke": "bash ./scripts/package-cli-smoke.sh",
    "install:cli:smoke": "npm run package:cli:smoke"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^24.0.0",
    "wrangler": "^4.20.0"
  },
  "packageManager": "yarn@4.9.2+sha512.1fc009bc09d13cfd0e19efa44cbfc2b9cf6ca61482725eb35bbc5e257e093ebf4130db6dfe15d604ff4b79efd8e1e8e99b25fa7d0a6197c9f9826358d4d65c3c"
}
